public class inserstion_sort {
    public static void main() {
        int[] arr = {4,6,3,7,2,1};
        for(int i =1 ; i<arr.length; i++) {
            int j = i ;
            while (j>0 && arr[j] < arr[j-1]) {
                int temp = arr[j];
                arr[j] = arr[j-1];
                arr[j-1] = temp;
                j--;
            }
        }
        for (int ele : arr) {
            System.out.print(ele + " ");
        }
    }
}
